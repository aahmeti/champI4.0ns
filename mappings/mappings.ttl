  rr:predicateObjectMap [ rr:predicate champ-onto:yieldFromBoardsInPercentage ; rr:objectMap [ rml:reference "Yield from the boards(%)" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:wasteThermalUseInPercentage ; rr:objectMap [ rml:reference "% Waste (thermal use)" ; rr:datatype xsd:integer ] ] .


