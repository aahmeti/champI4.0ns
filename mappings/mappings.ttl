@prefix rr: <http://www.w3.org/ns/r2rml#> .
@prefix rml: <http://semweb.mmlab.be/ns/rml#> .
@prefix ql: <http://semweb.mmlab.be/ns/ql#> .
@prefix champ-onto: <https://schema.champi40ns.eu#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .


<https://schema.champi40ns.eu/ForestMapping>
  rml:logicalSource [
    rml:source "../input/forest.csv" ;
    rml:referenceFormulation ql:CSV
  ];
  rr:subjectMap [
    rr:template "https://resource.champi40ns.eu/Log/{label}" ;
    rr:class champ-onto:Log ;
    rr:graphMap [ rr:constant <https://data.champi40ns.eu/forest/> ]
  ];
  rr:predicateObjectMap [ rr:predicate champ-onto:company ; rr:objectMap [ rml:reference "Company" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:country ; rr:objectMap [ rml:reference "Country" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:federalState ; rr:objectMap [ rml:reference "Federal state" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:municipality ; rr:objectMap [ rml:reference "Municipality" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:side ; rr:objectMap [ rml:reference "Side" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:woodSpecies ; rr:objectMap [ rml:reference "Wood species" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:harvestingDate ; rr:objectMap [ rml:reference "Harvesting date" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:gpsLat ; rr:objectMap [ rml:reference "GPS coordinate lat" ; rr:datatype xsd:float ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:gpsLong ; rr:objectMap [ rml:reference "GPS coordinate long" ; rr:datatype xsd:float ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:truncDiameterInCentimeters ; rr:objectMap [ rml:reference "Trunc diameter" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:sizeClass ; rr:objectMap [ rml:reference "Size class" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:qualityClass ; rr:objectMap [ rml:reference "Quality class" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:assortment ; rr:objectMap [ rml:reference "Assortment" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:lengthInMeters ; rr:objectMap [ rml:reference "Length" ; rr:datatype xsd:integer ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:lumberQuantity ; rr:objectMap [ rml:reference "Lumber quantity" ; rr:datatype xsd:float ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:moonPhase ; rr:objectMap [ rml:reference "Moon phase" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:dateOfSale ; rr:objectMap [ rml:reference "Date of Sale" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:customer ; rr:objectMap [ rml:reference "Customer" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:export ; rr:objectMap [ rml:reference "Export" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:nationalTrade ; rr:objectMap [ rml:reference "National Trade" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:certification ; rr:objectMap [ rml:reference "Certification" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:loadingPointLat ; rr:objectMap [ rml:reference "Loading point (GPS lat)" ] ] ;
  rr:predicateObjectMap [ rr:predicate champ-onto:loadingPointLong ; rr:objectMap [ rml:reference "Loading point (GPS long)" ; rr:datatype xsd:float ] ] .

<https://schema.champi40ns.eu/ProductMapping_A>
